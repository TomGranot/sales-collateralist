ANTHROPIC_API_KEY=

# Local development only. Keep `.env.local` out of git.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_TEAM_ID=
SLACK_BOT_USER_ID=
SLACK_ALLOWED_CHANNEL_IDS=
SLACK_ALLOWED_USER_IDS=

PORT=3000

MODA_MCP_SERVER_URL=https://mcp.moda.app
MODA_ORG_ID=
MODA_TEAM_ID=

# oauth or static_bearer
MODA_MCP_AUTH_MODE=oauth

# Required for oauth mode
MODA_MCP_ACCESS_TOKEN=
MODA_MCP_REFRESH_TOKEN=
MODA_MCP_CLIENT_ID=
MODA_MCP_CLIENT_SECRET=
MODA_MCP_TOKEN_ENDPOINT=
MODA_MCP_SCOPE=
MODA_MCP_RESOURCE=
MODA_MCP_EXPIRES_AT=
MODA_MCP_TOKEN_ENDPOINT_AUTH=client_secret_post

# Optional if Moda exposes a static bearer auth flow for your MCP deployment
MODA_MCP_BEARER_TOKEN=

MANAGED_AGENT_NAME=Collateralist
MANAGED_AGENT_MODEL=claude-sonnet-4-6
MANAGED_AGENT_ENV_NAME=slack-moda-cloud
MANAGED_AGENT_VAULT_NAME=slack-moda-mcp
STATE_FILE=.data/state.json
